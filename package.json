{
  "name": "mqtt-to-meshcoreio-map",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node --input-type=module -e \"import { cpSync } from 'node:fs'; cpSync('src/dashboard/assets', 'dist/dashboard/assets', { recursive: true });\"",
    "test": "npm run build && node --test \"tests/**/*.test.mjs\"",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@liamcottle/meshcore.js": "^1.13.0",
    "@noble/curves": "^2.2.0",
    "mqtt": "^5.15.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
