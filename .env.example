# MeshCore MQTT source broker(s).
# In Docker, localhost means the container itself. Use a broker DNS name, host
# IP, or a Compose service name for deployed containers.
#
# Supported MQTT.js URL schemes include:
# - mqtt://broker.example.com:1883
# - mqtts://broker.example.com:8883
# - ws://broker.example.com:8083/mqtt
# - wss://broker.example.com:8084/mqtt
#
# Single source (legacy): treated as SOURCE_1.
# SOURCE_MQTT_URL=mqtt://mqtt.example.com:1883
# SOURCE_MQTT_USERNAME=
# SOURCE_MQTT_PASSWORD=
# SOURCE_CLIENT_ID=mqtt-to-meshcoreio-map
# TOPIC_FILTER=meshcore/#
# SOURCE_NAME=My Broker  (legacy fallback; use SOURCE_1_NAME instead)
#
# Multiple sources: use numbered environment variables.
# SOURCE_N_NAME is an optional friendly name that appears in logs and the dashboard.
# Each source gets its own MQTT connection, client ID, and topic filter.
# SOURCE_1_NAME=Primary Broker
# SOURCE_1_MQTT_URL=mqtt://broker1.example.com:1883
# SOURCE_1_MQTT_USERNAME=user1
# SOURCE_1_MQTT_PASSWORD=pass1
# SOURCE_1_CLIENT_ID=mqtt-to-meshcoreio-map-1
# SOURCE_1_TOPIC_FILTER=meshcore/#
# SOURCE_2_NAME=Secondary Broker
# SOURCE_2_MQTT_URL=mqtt://broker2.example.com:1883
# SOURCE_2_TOPIC_FILTER=meshcore/#
# SOURCE_2_RECONNECT_PERIOD_MS=5000
# SOURCE_2_CONNECT_TIMEOUT_MS=30000
# SOURCE_2_REJECT_UNAUTHORIZED=true
#
# Supported per-source overrides (inherit from global defaults when unset):
# SOURCE_N_RECONNECT_PERIOD_MS  (default: 5000, range: 250-300000)
# SOURCE_N_CONNECT_TIMEOUT_MS   (default: 30000, range: 1000-300000)
# SOURCE_N_REJECT_UNAUTHORIZED  (default: true)

# MQTT connection behavior (global fallback for multi-source).
MQTT_RECONNECT_PERIOD_MS=5000
MQTT_CONNECT_TIMEOUT_MS=30000
# Keep TLS certificate verification enabled for mqtts:// and wss:// in normal
# deployments. Set this to false only for local tests with self-signed certs.
SOURCE_REJECT_UNAUTHORIZED=true

# MeshCore.io map upload behavior.
# The service generates a new ephemeral signing identity at startup and logs only
# the generated public key.
MESHCOREIO_API_URL=https://map.meshcore.io/api/v1/uploader/node
MESHCOREIO_DRY_RUN=false
MESHCOREIO_MIN_REUPLOAD_SECONDS=3600
MESHCOREIO_REQUEST_TIMEOUT_MS=10000
MESHCOREIO_WORKERS=1
MESHCOREIO_MAX_QUEUED_UPLOADS=200
MESHCOREIO_RETRIES_ALLOWED=3

# Logging.
TZ=Europe/Stockholm
LOG_COLOR=false

# Turso database path for observer radio status and dashboard MeshCore.io response history.
TURSO_PATH=/data/mqtt-to-meshcoreio-map.turso
# SQLITE_PATH is accepted as a backward-compatible fallback for TURSO_PATH.

# Optional read-only dashboard.
# When enabled in Docker Compose, publish container port 80 as host port 6543.
ENABLE_DASHBOARD=false
DASHBOARD_PORT=80
# Optional local-only fake adverts for checking the dashboard map.
DASHBOARD_DEMO_ADVERTS=false
